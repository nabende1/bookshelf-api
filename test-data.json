  "testSequence": {
    "description": "Follow this order for complete CRUD testing",
    "steps": [
      "1. Create 3 users from users array",
      "2. Create 5 books from books array",
      "3. Create reviews using the stored user and book IDs",
      "4. Create borrowing records using the stored user and book IDs",
      "5. Test GET single for each collection",
      "6. Test GET all for each collection",
      "7. Test UPDATE using updateExamples",
      "8. Test DELETE in reverse order: reviews → borrowing → books → users",
      "9. Verify deletions with GET all requests"
    ]
  },
  "curlTemplates": {
    "createBook": "curl -X POST http://localhost:8080/books -H 'Content-Type: application/json' -d '{JSON_OBJECT}'",
    "createUser": "curl -X POST http://localhost:8080/users -H 'Content-Type: application/json' -d '{JSON_OBJECT}'",
    "createReview": "curl -X POST http://localhost:8080/reviews -H 'Content-Type: application/json' -d '{JSON_OBJECT}'",
    "createBorrowing": "curl -X POST http://localhost:8080/borrowing -H 'Content-Type: application/json' -d '{JSON_OBJECT}'",
    "getAll": "curl http://localhost:8080/{COLLECTION}",
    "getSingle": "curl http://localhost:8080/{COLLECTION}/{ID}",
    "update": "curl -X PUT http://localhost:8080/{COLLECTION}/{ID} -H 'Content-Type: application/json' -d '{JSON_OBJECT}'",
    "delete": "curl -X DELETE http://localhost:8080/{COLLECTION}/{ID}"
  }
