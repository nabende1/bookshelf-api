    "/auth/login": {
      "get": {
        "tags": [
          "Auth"
        ],
        "summary": "Start login with GitHub OAuth",
        "description": "Redirects to GitHub for authentication. Returns token after successful login.",
        "responses": {
          "200": {
            "description": "OAuth helper response for API clients"
          },
          "302": {
            "description": "Redirect to GitHub OAuth"
          },
          "500": {
            "description": "GitHub OAuth not configured on server"
          }
        }
      }
    },
    "/auth/github": {
      "get": {
        "tags": [
          "Auth"
        ],
        "summary": "Start GitHub OAuth flow",
        "description": "Returns JSON helper in API clients and redirects to GitHub in browser flow.",
        "parameters": [
          {
            "name": "redirect",
            "in": "query",
            "description": "Set to true to force redirect flow.",
            "type": "boolean"
          }
        ],
        "responses": {
          "200": {
            "description": "OAuth helper response for API clients"
          },
          "302": {
            "description": "Redirect to GitHub OAuth"
          },
          "500": {
            "description": "GitHub OAuth not configured on server"
          }
        }
      }
    },
    "/auth/callback": {
      "get": {
        "tags": [
          "Auth"
        ],
        "summary": "GitHub OAuth callback",
        "description": "Handles the redirect from GitHub after user authorises the app. Not intended to be called directly from API clients.",
        "parameters": [
          {
            "name": "code",
            "in": "query",
            "type": "string"
          },
          {
            "name": "json",
            "in": "query",
            "type": "string"
          }
        ],
        "responses": {
          "200": {
            "description": "Authentication successful, returns JWT and user object"
          },
          "302": {
            "description": "Redirects to FRONTEND_URL with token if configured"
          },
          "400": {
            "description": "Bad Request"
          },
          "401": {
            "description": "Authentication failed or denied"
          },
          "500": {
            "description": "Internal Server Error"
          }
        }
      }
    },
    "/auth/failure": {
      "get": {
        "description": "",
        "responses": {
          "401": {
            "description": "Unauthorized"
          }
        }
      }
    },
    "/auth/logout": {
      "post": {
        "tags": [
          "Auth"
        ],
        "summary": "Logout user",
        "description": "JWT-based logout. Client should delete the token from local storage.",
        "responses": {
          "200": {
            "description": "Logout successful"
          }
        }
      }
    },
    "/auth/test-token": {
      "get": {
        "tags": [
          "Auth"
        ],
        "summary": "Get test token (Development Only)",
        "description": "Returns a test JWT token for development/testing without needing actual GitHub login. Only available in development environment.",
